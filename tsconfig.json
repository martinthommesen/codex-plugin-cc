{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "plugins/codex/scripts/**/*.mjs",
    "plugins/codex/scripts/lib/app-server-protocol.d.ts",
    "plugins/codex/.generated/app-server-types/**/*.ts"
  ]
}
